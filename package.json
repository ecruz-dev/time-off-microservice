{
  "name": "timeoff-microservice",
  "version": "0.1.0",
  "private": true,
  "description": "Time-Off Microservice assessment workspace",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "node ./node_modules/@nestjs/cli/bin/nest.js build timeoff-service && node ./node_modules/@nestjs/cli/bin/nest.js build hcm-mock",
    "build:timeoff-service": "node ./node_modules/@nestjs/cli/bin/nest.js build timeoff-service",
    "build:hcm-mock": "node ./node_modules/@nestjs/cli/bin/nest.js build hcm-mock",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "node ./node_modules/prisma/build/index.js migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "node ./node_modules/prisma/build/index.js migrate deploy --schema prisma/schema.prisma",
    "prisma:seed": "node ./node_modules/prisma/build/index.js db seed --schema prisma/schema.prisma",
    "start:timeoff-service": "node ./node_modules/@nestjs/cli/bin/nest.js start timeoff-service",
    "start:hcm-mock": "node ./node_modules/@nestjs/cli/bin/nest.js start hcm-mock",
    "start:dev:timeoff-service": "node ./node_modules/@nestjs/cli/bin/nest.js start timeoff-service --watch",
    "start:dev:hcm-mock": "node ./node_modules/@nestjs/cli/bin/nest.js start hcm-mock --watch",
    "lint": "node ./node_modules/eslint/bin/eslint.js \"{apps,libs,prisma}/**/*.ts\"",
    "format": "node ./node_modules/prettier/bin/prettier.cjs --write \"{apps,libs,docs,prisma,test}/**/*.{ts,js,json,md,prisma}\"",
    "test": "node ./node_modules/jest/bin/jest.js --config test/jest-unit.json --passWithNoTests",
    "test:e2e:timeoff-service": "node ./node_modules/jest/bin/jest.js --config apps/timeoff-service/test/jest-e2e.json",
    "test:e2e:hcm-mock": "node ./node_modules/jest/bin/jest.js --config apps/hcm-mock/test/jest-e2e.json",
    "test:e2e": "npm run test:e2e:timeoff-service && npm run test:e2e:hcm-mock"
  },
  "prisma": {
    "seed": "node -r ts-node/register prisma/seed.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "@nestjs/apollo": "^12.2.2",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/graphql": "^12.2.2",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.6.0",
    "graphql": "^16.9.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.24",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "prisma": "^6.6.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2"
  }
}
